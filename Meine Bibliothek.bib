  title = {The {{Banco}} de {{Espa\~na Business Activity Survey}}: 2025 {{Q2}}},
  shorttitle = {The {{Banco}} de {{Espa\~na Business Activity Survey}}},
  author = {Fern{\'a}ndez Cerezo, Alejandro and Izquierdo, Mario},
  year = 2025,
